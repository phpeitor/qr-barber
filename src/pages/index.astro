---
import Sidebar from '../components/Sidebar.astro';
import ReportForm from '../components/ReportForm.astro';
import ReportViewer from '../components/ReportViewer.astro';
import { initialReports, users } from '../data/initialReports';
import DashboardLayout from '../layouts/DashboardLayout.astro';

const serializedReports = JSON.stringify(initialReports).replace(/</g, '\\u003c');
const serializedUsers = JSON.stringify(users).replace(/</g, '\\u003c');
---

<DashboardLayout title="BI Reports Hub | Astro">
  <section class="panel login-panel" id="login-panel">
    <div class="login-copy">
      <p class="topbar-label">Acceso por rol</p>
      <h2>Ingresar al visor BI</h2>
      <p>Admin registra y visualiza. Operaciones, Finanzas y Comercial solo ven su propio menu y sus reportes.</p>
    </div>

    <form id="login-form" class="login-form" novalidate>
      <label class="field">
        <span>Usuario</span>
        <input id="login-user" name="user" type="text" placeholder="Ej: admin" autocomplete="off" required />
      </label>

      <label class="field">
        <span>Rol</span>
        <select id="login-role" name="role" required>
          <option value="admin">Admin</option>
          <option value="operaciones">Operaciones</option>
          <option value="finanzas">Finanzas</option>
          <option value="comercial">Comercial</option>
        </select>
      </label>

      <button class="primary-btn" type="submit">Entrar</button>
      <p class="form-message" id="login-message" role="status" aria-live="polite"></p>
    </form>
  </section>

  <div class="toast" id="toast" role="status" aria-live="polite" aria-atomic="true"></div>

  <div class="dashboard-shell is-hidden" id="app-root">
    <Sidebar />

    <main class="content-area">
      <header class="topbar">
        <div>
          <p class="topbar-label">Plataforma de inteligencia</p>
          <h2>Centro de Reportes Embebidos</h2>
          <p class="session-note" id="session-note">Sesión inactiva</p>
        </div>

        <div class="topbar-actions">
          <button class="ghost-btn" type="button" id="theme-toggle" aria-label="Cambiar tema">
            Cambiar tema
          </button>
          <button class="ghost-btn ghost-danger" type="button" id="logout-btn">Salir</button>
        </div>
      </header>

      <section class="content-grid" id="workspace-grid">
        <div class="admin-stack" id="admin-stack">
          <ReportForm />

          <section class="panel admin-table-panel" id="admin-table-panel" aria-labelledby="table-title">
            <div class="panel-head">
              <h2 id="table-title">Reportes registrados</h2>
              <p>Inventario completo visible solo para el rol admin.</p>
            </div>

            <div class="table-shell">
              <table class="reports-table">
                <thead>
                  <tr>
                    <th>Nombre</th>
                    <th>Modulo</th>
                    <th>Plataforma</th>
                    <th>URL</th>
                  </tr>
                </thead>
                <tbody id="reports-table-body"></tbody>
              </table>
            </div>
          </section>
        </div>

        <ReportViewer />
      </section>
    </main>
  </div>

  <script type="module" define:vars={{ serializedReports, serializedUsers }}>
    /** @typedef {'admin' | 'operaciones' | 'finanzas' | 'comercial'} AppRole */
    /** @typedef {'powerbi' | 'tableau' | 'other'} BiPlatform */
    /** @typedef {'iframe-public' | 'official-sdk' | 'secure-token'} EmbedStrategy */

    /** @typedef {{
     * id: string;
     * name: string;
     * module: string;
     * url: string;
     * platform: BiPlatform;
     * strategy: EmbedStrategy;
     * }} ReportItem
     */

    /** @typedef {{ user: string; role: AppRole }} SessionState */

    /** @typedef {{ user: string; role: AppRole; displayName?: string }} UserItem */

    const REPORTS_KEY = 'bi-reports-v1';
    const AUTH_KEY = 'bi-auth-v1';
    const THEME_KEY = 'bi-theme-v1';

    /** @type {ReportItem[]} */
    const initialReportsState = JSON.parse(serializedReports);
    /** @type {UserItem[]} */
    const userList = JSON.parse(serializedUsers);

    /** @type {ReportItem[]} */
    let reports = loadReports();
    /** @type {SessionState | null} */
    let session = loadSession();
    let selectedReportId = '';
    let selectedModule = '';

    const loginPanel = document.querySelector('#login-panel');
    const loginForm = document.querySelector('#login-form');
    const loginMessage = document.querySelector('#login-message');
    const loginUser = document.querySelector('#login-user');
    const loginRole = document.querySelector('#login-role');
    const toast = document.querySelector('#toast');
    const appRoot = document.querySelector('#app-root');
    const sessionNote = document.querySelector('#session-note');
    const sidebarSession = document.querySelector('#sidebar-session');
    const sidebarMenu = document.querySelector('#sidebar-menu');
    const sidebarModules = document.querySelector('#sidebar-modules');
    const reportForm = document.querySelector('#report-form');
    const reportMeta = document.querySelector('#report-meta');
    const platformChip = document.querySelector('#platform-chip');
    const embedGuidance = document.querySelector('#embed-guidance');
    const reportFrame = document.querySelector('#report-frame');
    const formMessage = document.querySelector('#form-message');
    const reportsTableBody = document.querySelector('#reports-table-body');
    const adminStack = document.querySelector('#admin-stack');
    const workspaceGrid = document.querySelector('#workspace-grid');
    const themeToggle = document.querySelector('#theme-toggle');
    const logoutBtn = document.querySelector('#logout-btn');
    const sidebarToggle = document.querySelector('#sidebar-toggle');

    const roleLabels = {
      admin: 'Admin',
      operaciones: 'Operaciones',
      finanzas: 'Finanzas',
      comercial: 'Comercial'
    };

    const roleModules = {
      admin: null,
      operaciones: 'Operaciones',
      finanzas: 'Finanzas',
      comercial: 'Comercial'
    };

    applyThemeFromStorage();

    function loadReports() {
      try {
        const saved = localStorage.getItem(REPORTS_KEY);
        if (!saved) {
          return [...initialReportsState];
        }

        const parsed = JSON.parse(saved);
        return Array.isArray(parsed) ? parsed : [...initialReportsState];
      } catch {
        return [...initialReportsState];
      }
    }

    /** @returns {SessionState | null} */
    function loadSession() {
      try {
        const saved = localStorage.getItem(AUTH_KEY);
        if (!saved) {
          return null;
        }

        const parsed = JSON.parse(saved);
        if (!parsed || typeof parsed.user !== 'string' || typeof parsed.role !== 'string') {
          return null;
        }

        return /** @type {SessionState} */ (parsed);
      } catch {
        return null;
      }
    }

    function applyThemeFromStorage() {
      const savedTheme = localStorage.getItem(THEME_KEY);
      if (savedTheme === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    }

    function saveReports() {
      localStorage.setItem(REPORTS_KEY, JSON.stringify(reports));
    }

    /** @param {string} user */
    function findUser(user) {
      return userList.find((item) => item.user.toLowerCase() === user.toLowerCase()) ?? null;
    }

    let toastTimer;

    function showToast(message, tone = 'error') {
      if (!toast) {
        return;
      }

      toast.textContent = message;
      toast.dataset.state = tone;
      toast.classList.add('is-visible');

      window.clearTimeout(toastTimer);
      toastTimer = window.setTimeout(() => {
        toast.classList.remove('is-visible');
      }, 2800);
    }

    /** @param {SessionState | null} nextSession */
    function saveSession(nextSession) {
      if (!nextSession) {
        localStorage.removeItem(AUTH_KEY);
        return;
      }

      localStorage.setItem(AUTH_KEY, JSON.stringify(nextSession));
    }

    const uniqueId = () => {
      if (window.crypto?.randomUUID) {
        return window.crypto.randomUUID();
      }

      return `report-${Date.now()}-${Math.floor(Math.random() * 99999)}`;
    };

    /** @param {string} value */
    function shortLabel(value) {
      return value
        .split(/\s+/)
        .filter(Boolean)
        .slice(0, 2)
        .map((word) => word[0]?.toUpperCase() ?? '')
        .join('');
    }

    /** @param {string} value */
    function escapeHtml(value) {
      return value
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    /** @param {string} url */
    function detectPlatform(url) {
      const lowered = url.toLowerCase();

      if (lowered.includes('powerbi') || lowered.includes('fabric.microsoft.com')) {
        return 'powerbi';
      }

      if (lowered.includes('tableau')) {
        return 'tableau';
      }

      return 'other';
    }

    /** @param {string} url */
    function resolveStrategy(url) {
      const lowered = url.toLowerCase();
      const platform = detectPlatform(url);

      if (platform === 'powerbi') {
        if (lowered.includes('fabric.microsoft.com/view?r=')) {
          return 'iframe-public';
        }

        if (lowered.includes('reportembed')) {
          return 'secure-token';
        }

        return 'official-sdk';
      }

      if (platform === 'tableau') {
        if (lowered.includes('public.tableau.com')) {
          return 'iframe-public';
        }

        return 'official-sdk';
      }

      return 'iframe-public';
    }

    /** @param {string} url */
    function normalizeUrl(url) {
      const platform = detectPlatform(url);

      if (platform !== 'tableau') {
        return url;
      }

      try {
        const parsed = new URL(url);
        if (!parsed.searchParams.has(':showVizHome')) {
          parsed.searchParams.set(':showVizHome', 'no');
        }

        return parsed.toString();
      } catch {
        return url;
      }
    }

    /** @param {ReportItem} report */
    function guidanceText(report) {
      const hints = {
        'iframe-public': 'URL publica detectada. Se usa iframe por simplicidad y rendimiento.',
        'official-sdk': 'Para mayor control usa embedding oficial de la plataforma con eventos y token cuando aplique.',
        'secure-token': 'URL segura detectada. En produccion usa embedding oficial con backend y token seguro.'
      };

      return hints[report.strategy];
    }

    /** @param {AppRole} role */
    function getRoleModule(role) {
      return roleModules[role];
    }

    /** @param {AppRole} role */
    function getVisibleReports(role = session?.role ?? 'admin') {
      if (role === 'admin') {
        return [...reports];
      }

      const moduleName = getRoleModule(role);
      return reports.filter((report) => report.module === moduleName);
    }

    /** @param {AppRole} role */
    function getAllowedModules(role = session?.role ?? 'admin') {
      const visibleReports = getVisibleReports(role);
      return [...new Set(visibleReports.map((report) => report.module))].sort((a, b) => a.localeCompare(b, 'es'));
    }

    function ensureSelection() {
      const visibleReports = getVisibleReports();

      if (!visibleReports.length) {
        selectedReportId = '';
        selectedModule = session?.role ? (getRoleModule(session.role) ?? '') : '';
        return;
      }

      const selectedReport = visibleReports.find((report) => report.id === selectedReportId);
      if (selectedReport) {
        selectedModule = selectedReport.module;
        return;
      }

      selectedReportId = visibleReports[0].id;
      selectedModule = visibleReports[0].module;
    }

    function updateSessionLabels() {
      if (!session) {
        return;
      }

      const label = `${session.user} | ${roleLabels[session.role]}`;
      if (sessionNote) {
        sessionNote.textContent = label;
      }

      if (sidebarSession) {
        sidebarSession.textContent = label;
      }
    }

    function renderAdminState() {
      if (!adminStack || !workspaceGrid || !reportForm) {
        return;
      }

      const isAdmin = session?.role === 'admin';
      adminStack.hidden = !isAdmin;
      reportForm.hidden = !isAdmin;
      workspaceGrid.classList.toggle('single-view', !isAdmin);
    }

    function renderLoginState() {
      const loggedIn = Boolean(session);
      if (loginPanel) {
        loginPanel.hidden = loggedIn;
      }

      if (appRoot) {
        appRoot.classList.toggle('is-hidden', !loggedIn);
      }

      if (loggedIn) {
        updateSessionLabels();
      }
    }

    function renderSidebar() {
      if (!sidebarMenu || !sidebarModules) {
        return;
      }

      if (!session) {
        sidebarMenu.innerHTML = '';
        sidebarModules.innerHTML = '';
        return;
      }

      const visibleReports = getVisibleReports();
      const modules = getAllowedModules();

      sidebarMenu.innerHTML = modules
        .map((moduleName) => {
          const activeClass = moduleName === selectedModule ? 'active' : '';
          const count = visibleReports.filter((report) => report.module === moduleName).length;
          const label = escapeHtml(moduleName);
          const badge = escapeHtml(shortLabel(moduleName));
          return `<button class="menu-item has-tooltip ${activeClass}" type="button" data-module="${label}" data-tooltip="${label}" aria-label="${label}"><span class="menu-icon" aria-hidden="true">${badge}</span><span class="menu-label">${label}</span><span class="menu-count">${count}</span></button>`;
        })
        .join('');

      const grouped = visibleReports.reduce((acc, report) => {
        if (!acc[report.module]) {
          acc[report.module] = [];
        }

        acc[report.module].push(report);
        return acc;
      }, /** @type {Record<string, ReportItem[]>} */ ({}));

      sidebarModules.innerHTML = Object.entries(grouped)
        .sort(([a], [b]) => a.localeCompare(b, 'es'))
        .map(([moduleName, moduleReports], index) => {
          const open = moduleName === selectedModule || (index === 0 && !selectedModule) ? 'open' : '';
          const moduleLabel = escapeHtml(moduleName);
          const moduleBadge = escapeHtml(shortLabel(moduleName));

          const reportsHtml = moduleReports
            .map((report) => {
              const selectedClass = report.id === selectedReportId ? 'active' : '';
              const reportLabel = escapeHtml(report.name);
              const reportId = escapeHtml(report.id);
              const reportBadge = escapeHtml(shortLabel(report.name));

              return `<li><button class="report-link has-tooltip ${selectedClass}" data-report-id="${reportId}" type="button" data-tooltip="${reportLabel}" aria-label="${reportLabel}"><span class="report-dot" aria-hidden="true">${reportBadge}</span><span class="report-label">${reportLabel}</span></button></li>`;
            })
            .join('');

          return `
            <details class="module-group" ${open} data-module-group="${moduleLabel}">
              <summary class="module-summary has-tooltip" data-tooltip="${moduleLabel}"><span class="module-badge" aria-hidden="true">${moduleBadge}</span><span class="module-label">${moduleLabel}</span></summary>
              <ul class="module-list">${reportsHtml}</ul>
            </details>
          `;
        })
        .join('');

      bindSidebarActions();
    }

    function renderTable() {
      if (!reportsTableBody) {
        return;
      }

      const visibleReports = getVisibleReports();
      if (session?.role !== 'admin') {
        reportsTableBody.innerHTML = '';
        return;
      }

      if (!visibleReports.length) {
        reportsTableBody.innerHTML = '<tr><td colspan="4">No hay reportes registrados.</td></tr>';
        return;
      }

      reportsTableBody.innerHTML = visibleReports
        .map((report) => {
          const name = escapeHtml(report.name);
          const moduleName = escapeHtml(report.module);
          const platform = escapeHtml(report.platform.toUpperCase());
          const url = escapeHtml(report.url);
          return `<tr><td>${name}</td><td>${moduleName}</td><td>${platform}</td><td><a href="${url}" target="_blank" rel="noreferrer">Abrir</a></td></tr>`;
        })
        .join('');
    }

    function updateViewer() {
      if (!reportMeta || !platformChip || !embedGuidance || !reportFrame) {
        return;
      }

      const visibleReports = getVisibleReports();
      const selected = visibleReports.find((report) => report.id === selectedReportId) ?? visibleReports[0];

      if (!selected) {
        reportMeta.textContent = 'No hay reportes disponibles para este rol.';
        platformChip.textContent = 'Sin datos';
        embedGuidance.textContent = 'Registra reportes desde admin o cambia de rol para ver contenido.';
        reportFrame.removeAttribute('src');
        return;
      }

      selectedReportId = selected.id;
      selectedModule = selected.module;
      reportMeta.textContent = `${selected.module} | ${selected.name}`;
      platformChip.textContent = `${selected.platform.toUpperCase()} | ${selected.strategy}`;
      embedGuidance.textContent = guidanceText(selected);
      reportFrame.src = normalizeUrl(selected.url);

      document.querySelectorAll('.report-link').forEach((link) => {
        link.classList.toggle('active', link.getAttribute('data-report-id') === selected.id);
      });

      document.querySelectorAll('.menu-item').forEach((button) => {
        button.classList.toggle('active', button.getAttribute('data-module') === selected.module);
      });

      document.querySelectorAll('.module-group').forEach((details) => {
        details.open = details.getAttribute('data-module-group') === selected.module;
      });
    }

    function bindSidebarActions() {
      document.querySelectorAll('.menu-item').forEach((button) => {
        button.addEventListener('click', () => {
          const moduleName = button.getAttribute('data-module');
          if (!moduleName) {
            return;
          }

          const moduleReports = getVisibleReports().filter((report) => report.module === moduleName);
          if (!moduleReports.length) {
            return;
          }

          selectedModule = moduleName;
          selectedReportId = moduleReports[0].id;
          renderSidebar();
          renderTable();
          updateViewer();
        });
      });

      document.querySelectorAll('.report-link').forEach((button) => {
        button.addEventListener('click', () => {
          const reportId = button.getAttribute('data-report-id');
          if (!reportId) {
            return;
          }

          const report = getVisibleReports().find((item) => item.id === reportId);
          if (!report) {
            return;
          }

          selectedReportId = report.id;
          selectedModule = report.module;
          renderSidebar();
          renderTable();
          updateViewer();
        });
      });
    }

    function setMessage(message, isError = false) {
      if (!formMessage) {
        return;
      }

      formMessage.textContent = message;
      formMessage.dataset.state = isError ? 'error' : 'ok';
    }

    loginForm?.addEventListener('submit', (event) => {
      event.preventDefault();

      const formData = new FormData(loginForm);
      const user = String(formData.get('user') ?? '').trim();
      const role = String(formData.get('role') ?? 'admin');

      if (!user) {
        if (loginMessage) {
          loginMessage.textContent = 'Selecciona un usuario valido.';
          loginMessage.dataset.state = 'error';
        }

        showToast('Selecciona un usuario válido.', 'error');
        return;
      }

      const matchedUser = findUser(user);
      if (!matchedUser) {
        if (loginMessage) {
          loginMessage.textContent = 'El usuario no existe en la lista permitida.';
          loginMessage.dataset.state = 'error';
        }

        showToast('El usuario no existe en la lista permitida.', 'error');

        return;
      }

      if (matchedUser.role !== role) {
        if (loginMessage) {
          loginMessage.textContent = 'El rol no coincide con el usuario seleccionado.';
          loginMessage.dataset.state = 'error';
        }

        showToast('El rol no coincide con el usuario seleccionado.', 'error');

        return;
      }

      session = {
        user: matchedUser.user,
        role: /** @type {AppRole} */ (matchedUser.role)
      };

      saveSession(session);
      ensureSelection();
      renderLoginState();
      renderAdminState();
      updateSessionLabels();
      renderSidebar();
      renderTable();
      updateViewer();
      showToast(`Bienvenido, ${matchedUser.displayName ?? matchedUser.user}.`, 'success');
    });

    logoutBtn?.addEventListener('click', () => {
      session = null;
      saveSession(null);
      selectedReportId = '';
      selectedModule = '';
      renderLoginState();
      renderAdminState();
      renderSidebar();
      renderTable();
      updateViewer();
      if (loginForm) {
        loginForm.reset();
      }
    });

    sidebarToggle?.addEventListener('click', () => {
      appRoot?.classList.toggle('sidebar-collapsed');
    });

    themeToggle?.addEventListener('click', () => {
      const nextTheme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', nextTheme);
      localStorage.setItem(THEME_KEY, nextTheme);
    });

    reportForm?.addEventListener('submit', (event) => {
      event.preventDefault();

      if (session?.role !== 'admin') {
        setMessage('Solo admin puede registrar reportes.', true);
        return;
      }

      const formData = new FormData(reportForm);
      const name = String(formData.get('name') ?? '').trim();
      const module = String(formData.get('module') ?? '').trim();
      const url = String(formData.get('url') ?? '').trim();
      const platformInput = String(formData.get('platform') ?? 'auto');

      if (!name || !module || !url) {
        setMessage('Completa todos los campos obligatorios.', true);
        return;
      }

      try {
        new URL(url);
      } catch {
        setMessage('La URL del reporte no es valida.', true);
        return;
      }

      const autoPlatform = detectPlatform(url);
      const finalPlatform = platformInput === 'auto' ? autoPlatform : platformInput;

      /** @type {ReportItem} */
      const newReport = {
        id: uniqueId(),
        name,
        module,
        url,
        platform: /** @type {BiPlatform} */ (finalPlatform),
        strategy: resolveStrategy(url)
      };

      reports.push(newReport);
      saveReports();
      selectedReportId = newReport.id;
      selectedModule = newReport.module;
      renderSidebar();
      renderTable();
      updateViewer();
      reportForm.reset();
      setMessage('Reporte registrado correctamente.');
    });

    ensureSelection();
    renderLoginState();
    renderAdminState();
    if (session) {
      renderSidebar();
      renderTable();
      updateViewer();
    }
  </script>
</DashboardLayout>
