<section class="panel viewer-panel" aria-labelledby="viewer-title">
  <div class="panel-head viewer-head">
    <div>
      <h2 id="viewer-title">Visor de Reportes</h2>
      <p id="report-meta">Selecciona un reporte para iniciar.</p>
    </div>
    <span class="chip" id="platform-chip">Sin seleccionar</span>
  </div>

  <div class="embed-guidance" id="embed-guidance"></div>

  <div class="embed-frame-wrap">
    <iframe
      id="report-frame"
      title="Reporte BI embebido"
      loading="lazy"
      referrerpolicy="no-referrer"
      allow="fullscreen"
    ></iframe>
  </div>
</section>
